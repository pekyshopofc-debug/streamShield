# Database (use volume path in production)
DATABASE_URL="file:/data/streamshield.db"

# Auth — gere com: openssl rand -hex 32
JWT_SECRET="change-this-to-a-very-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# App URL (com https em produção)
NEXT_PUBLIC_APP_URL="https://seu-dominio.com"

# yt-dlp (caminho dentro do container)
YTDLP_PATH="/usr/local/bin/yt-dlp"

# Opcional: cookies do YouTube para melhor qualidade
# YOUTUBE_COOKIE=""

# Rate limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="60"
